@page
@model IndexModel
@{
    ViewData["Title"] = "Horde Defense";
}

<div class="game-container text-center">
    <h1 class="display-4 text-danger mb-3" style="font-family: 'Courier New', Courier, monospace; font-weight: bold;">DEFEND THE CASTLE</h1>
    
    <div class="row">
        <div class="col-md-3">
            <div class="card bg-dark text-white mb-3">
                <div class="card-header">
                    <h3>Keep HQ</h3>
                </div>
                <div class="card-body">
                    <h4 class="text-warning">Supplies: <span id="suppliesDisplay">1000</span></h4>
                    <p>Phase: <span id="phaseDisplay" class="text-info font-weight-bold">Entrenchment</span></p>
                    <hr class="bg-secondary" />
                    
                    <h5>Build Defenses</h5>
                    <div class="d-grid gap-2 build-menu">
                        <button class="btn btn-outline-secondary text-start build-btn active" data-type="trench" data-cost="20">
                            🟫 Trench (20) <small class="d-block text-muted">Blocks path, bullets fly over</small>
                        </button>
                        <button class="btn btn-outline-secondary text-start build-btn" data-type="wire" data-cost="30">
                            ➰ Barbed Wire (30) <small class="d-block text-muted">Slows horde</small>
                        </button>
                        <button class="btn btn-outline-secondary text-start build-btn" data-type="maxim" data-cost="150">
                            🔫 Maxim Gun (150) <small class="d-block text-muted">Sprays piercing bullets</small>
                        </button>
                        <button class="btn btn-outline-secondary text-start build-btn" data-type="moat" data-cost="80">
                            🐊 Croc Moat (80) <small class="d-block text-muted">Eats 5 horders</small>
                        </button>
                        <button class="btn btn-outline-secondary text-start build-btn" data-type="oil" data-cost="30">
                            🛢️ Oil Slick (30) <small class="d-block text-muted">Makes 'em slip & spin</small>
                        </button>
                        <button class="btn btn-outline-secondary text-start build-btn" data-type="claymore" data-cost="60">
                            💥 Claymore (60) <small class="d-block text-muted">Aimed explosive. Triggers on mass movement + smoke</small>
                        </button>
                        <button class="btn btn-outline-danger text-start build-btn" data-type="remove" data-cost="0">
                            🗑️ Demolish <small class="d-block text-muted">Refunds 50%</small>
                        </button>
                    </div>

                    <hr class="bg-secondary" />
                    <button id="rerollBtn" class="btn btn-outline-info btn-sm w-100 mb-2">🎲 Reroll Terrain</button>
                    <button id="startWaveBtn" class="btn btn-danger btn-lg w-100 fw-bold">🚀 LAUNCH HORDE</button>
                    <button id="replayBtn" class="btn btn-info btn-sm w-100 mt-2" style="display:none;">🔄 Replay Wave (Same Horde)</button>
                    <button id="replayEntrenchBtn" class="btn btn-outline-info btn-sm w-100 mt-2" style="display:none;">🏗️ Replay Wave (Use Current Supplies)</button>
                    <button id="tryAgainBtn" class="btn btn-success btn-sm w-100 mt-2" style="display:none;">🛠️ Modify Defenses (+200 Supplies)</button>
                    <button id="nextWaveBtn" class="btn btn-primary btn-sm w-100 mt-2" style="display:none;">🌊 Next Wave (x1.5 Horde)</button>
                    <button id="restartBtn" class="btn btn-warning btn-sm w-100 mt-2" style="display:none;">🗺️ New Map / Restart</button>
                </div>
            </div>
            <div class="alert alert-info small text-start">
                <strong>Tip:</strong> The Castle Keep is in the center. The horde spawns from all sides! Channel them using trenches and use Maxims to cover lanes.
            </div>
        </div>
        
        <div class="col-md-9 mb-4 mx-auto text-center">
            <div class="bg-secondary p-2 rounded shadow d-inline-block w-100">
                <canvas id="gameCanvas" width="640" height="640" style="max-width: 100%; height: auto;" class="border border-dark shadow-lg bg-dark"></canvas>
            </div>
            
            <!-- Silly feedback area -->
            <div id="battleLog" class="text-start mt-3 p-3 bg-light rounded text-dark" style="height: 150px; overflow-y: auto; font-family: monospace;">
                System: Defenses online. Awaiting entrenchment orders.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/game.js" asp-append-version="true"></script>
}
